{
    "name": "agent-wallet-runtime",
    "version": "1.0.0",
    "description": "Autonomous wallet runtime for AI agents on Solana devnet — agents emit intents, the runtime validates, simulates, signs, and broadcasts.",
    "main": "dist/index.js",
    "bin": {
        "agent-wallet": "dist/cli/index.js"
    },
    "scripts": {
        "build": "tsc",
        "start": "node dist/cli/index.js",
        "dev": "ts-node src/cli/index.ts",
        "dev:web": "ts-node src/cli/index.ts web --port 3000",
        "web": "node dist/cli/index.js web --port 3000",
        "test": "jest --forceExit --detectOpenHandles --testPathIgnorePatterns=integration",
        "test:integration": "jest --forceExit --detectOpenHandles --testPathPattern=integration",
        "clean": "rimraf dist"
    },
    "keywords": [
        "solana",
        "wallet",
        "ai-agent",
        "autonomous",
        "devnet",
        "hd-wallet",
        "agentic"
    ],
    "license": "MIT",
    "dependencies": {
        "@solana/spl-token": "^0.4.14",
        "@solana/web3.js": "^1.98.0",
        "bip39": "^3.1.0",
        "bs58": "^5.0.0",
        "commander": "^12.0.0",
        "dotenv": "^16.4.5",
        "ed25519-hd-key": "^1.3.0",
        "ethers": "^6.16.0",
        "sql.js": "^1.10.0",
        "winston": "^3.13.0"
    },
    "devDependencies": {
        "@types/jest": "^29.5.12",
        "@types/node": "^20.0.0",
        "jest": "^29.7.0",
        "rimraf": "^5.0.5",
        "ts-jest": "^29.1.4",
        "ts-node": "^10.9.2",
        "typescript": "^5.4.5"
    }
}
